  <ReportParameters>
    <ReportParameter Name="StartDate">
      <DataType>DateTime</DataType>
      <DefaultValue>
        <Values>
          <Value>=DateSerial(Year(Today()), Month(Today()), 1)</Value>
        </Values>
      </DefaultValue>
      <Prompt>Start Date</Prompt>
    </ReportParameter>
    <ReportParameter Name="EndDate">
      <DataType>DateTime</DataType>
      <DefaultValue>
        <Values>
          <Value>=Today()</Value>
        </Values>
      </DefaultValue>
      <Prompt>End Date</Prompt>
    </ReportParameter>
    <ReportParameter Name="StatusFilter">
      <DataType>String</DataType>
      <DefaultValue>
        <Values>
          <Value>All</Value>
        </Values>
      </DefaultValue>
      <Prompt>Status</Prompt>
    </ReportParameter>
    <ReportParameter Name="EmployeeFilter">
      <DataType>String</DataType>
      <AllowBlank>true</AllowBlank>
      <DefaultValue>
        <Values>
          <Value>All</Value>
        </Values>
      </DefaultValue>
      <Prompt>Employee</Prompt>
    </ReportParameter>
    <ReportParameter Name="BillableFilter">
      <DataType>String</DataType>
      <DefaultValue>
        <Values>
          <Value>All</Value>
        </Values>
      </DefaultValue>
      <Prompt>Billable</Prompt>
    </ReportParameter>
    <ReportParameter Name="SearchTerm">
      <DataType>String</DataType>
      <AllowBlank>true</AllowBlank>
      <DefaultValue>
        <Values>
          <Value></Value>
        </Values>
      </DefaultValue>
      <Prompt>Search</Prompt>
    </ReportParameter>
