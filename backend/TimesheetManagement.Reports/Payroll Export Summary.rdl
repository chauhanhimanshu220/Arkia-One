                <TextRuns>
                  <TextRun>
                    <Value>="Range Covered: " &amp; IIF(IsNothing(First(Fields!RangeStart.Value, "PayrollExportSummary")), "No data", Format(First(Fields!RangeStart.Value, "PayrollExportSummary"), "dd-MMM-yyyy") &amp; " to " &amp; Format(First(Fields!RangeEnd.Value, "PayrollExportSummary"), "dd-MMM-yyyy"))</Value>
