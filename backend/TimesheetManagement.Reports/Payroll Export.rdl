<?xml version="1.0" encoding="utf-8"?>
<Report MustUnderstand="df" xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily">
  <df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily>
  <AutoRefresh>0</AutoRefresh>
  <DataSets>
    <DataSet Name="PayrollExportSummary">
      <SharedDataSet>
        <SharedDataSetReference>PayrollExportSummary</SharedDataSetReference>
        <QueryParameters>
          <QueryParameter Name="@StartDate">
            <Value>=Parameters!StartDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@EndDate">
            <Value>=Parameters!EndDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@StatusFilter">
            <Value>=Parameters!StatusFilter.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@EmployeeFilter">
            <Value>=Parameters!EmployeeFilter.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@BillableFilter">
            <Value>=Parameters!BillableFilter.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@SearchTerm">
            <Value>=Parameters!SearchTerm.Value</Value>
          </QueryParameter>
        </QueryParameters>
      </SharedDataSet>
      <Fields>
        <Field Name="VisibleEntries">
          <DataField>VisibleEntries</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="VisibleHours">
          <DataField>VisibleHours</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="Employees">
          <DataField>Employees</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="SubmittedRows">
          <DataField>SubmittedRows</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="Projects">
          <DataField>Projects</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="RangeStart">
          <DataField>RangeStart</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="RangeEnd">
          <DataField>RangeEnd</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="PayrollExportDetail">
      <SharedDataSet>
        <SharedDataSetReference>PayrollExportDetail</SharedDataSetReference>
        <QueryParameters>
          <QueryParameter Name="@StartDate">
            <Value>=Parameters!StartDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@EndDate">
            <Value>=Parameters!EndDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@StatusFilter">
            <Value>=Parameters!StatusFilter.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@EmployeeFilter">
            <Value>=Parameters!EmployeeFilter.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@BillableFilter">
            <Value>=Parameters!BillableFilter.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@SearchTerm">
            <Value>=Parameters!SearchTerm.Value</Value>
          </QueryParameter>
        </QueryParameters>
      </SharedDataSet>
      <Fields>
        <Field Name="EmployeeName">
          <DataField>EmployeeName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="EmployeeEmail">
          <DataField>EmployeeEmail</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TimesheetStatus">
          <DataField>TimesheetStatus</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="EntryDate">
          <DataField>EntryDate</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="ProjectName">
          <DataField>ProjectName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TaskName">
          <DataField>TaskName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="BillableLabel">
          <DataField>BillableLabel</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="EntryHours">
          <DataField>EntryHours</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="EntryNote">
          <DataField>EntryNote</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
  <ReportSections>
    <ReportSection>
      <Body>
        <ReportItems>
          <Textbox Name="ReportTitle">
            <CanGrow>true</CanGrow>
            <KeepTogether>true</KeepTogether>
            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>Payroll Export</Value>
                    <Style>
                      <FontSize>18pt</FontSize>
                      <FontWeight>Bold</FontWeight>
                    </Style>
                  </TextRun>
                </TextRuns>
                <Style />
              </Paragraph>
            </Paragraphs>
            <Top>0cm</Top>
            <Left>0cm</Left>
            <Height>0.8cm</Height>
            <Width>10cm</Width>
            <Style>
              <PaddingLeft>2pt</PaddingLeft>
              <PaddingRight>2pt</PaddingRight>
              <PaddingTop>2pt</PaddingTop>
              <PaddingBottom>2pt</PaddingBottom>
            </Style>
          </Textbox>
          <Textbox Name="ReportSubtitle">
            <CanGrow>true</CanGrow>
            <KeepTogether>true</KeepTogether>
            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>Date-filtered timesheet payroll export powered by SSRS shared datasets.</Value>
                    <Style>
                      <Color>#52525b</Color>
                    </Style>
                  </TextRun>
                </TextRuns>
                <Style />
              </Paragraph>
            </Paragraphs>
            <Top>0.9cm</Top>
            <Left>0cm</Left>
            <Height>0.6cm</Height>
            <Width>18cm</Width>
            <Style>
              <PaddingLeft>2pt</PaddingLeft>
              <PaddingRight>2pt</PaddingRight>
              <PaddingTop>2pt</PaddingTop>
              <PaddingBottom>2pt</PaddingBottom>
            </Style>
          </Textbox>
          <Textbox Name="FiltersSummary">
            <CanGrow>true</CanGrow>
            <KeepTogether>true</KeepTogether>
            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>="Date: " &amp; Format(Parameters!StartDate.Value, "yyyy-MM-dd") &amp; " to " &amp; Format(Parameters!EndDate.Value, "yyyy-MM-dd") &amp; " | Status: " &amp; Parameters!StatusFilter.Value &amp; " | Employee: " &amp; Parameters!EmployeeFilter.Value &amp; " | Billable: " &amp; Parameters!BillableFilter.Value &amp; " | Search: " &amp; IIF(Len(Trim(Parameters!SearchTerm.Value)) = 0, "Any", Parameters!SearchTerm.Value)</Value>
                    <Style>
                      <Color>#3f3f46</Color>
                    </Style>
                  </TextRun>
                </TextRuns>
                <Style />
              </Paragraph>
            </Paragraphs>
            <Top>1.7cm</Top>
            <Left>0cm</Left>
            <Height>0.8cm</Height>
            <Width>26.5cm</Width>
            <Style>
              <Border>
                <Color>#d4d4d8</Color>
                <Style>Solid</Style>
              </Border>
              <BackgroundColor>#fafafa</BackgroundColor>
              <PaddingLeft>6pt</PaddingLeft>
              <PaddingRight>6pt</PaddingRight>
              <PaddingTop>6pt</PaddingTop>
              <PaddingBottom>6pt</PaddingBottom>
            </Style>
          </Textbox>
          <Textbox Name="SummaryEntries">
